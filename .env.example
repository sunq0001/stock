# 上证PE项目本地开发环境配置

# 数据源配置: 'local_db' 或 'remote_api'
DATA_SOURCE=remote_api

# 本地数据库路径（当DATA_SOURCE=local_db时使用）
LOCAL_DB_PATH=sse_pe_data.db

# 远程API地址（当DATA_SOURCE=remote_api时使用）
REMOTE_API_URL=http://101.43.3.247:8082/api/market/pe

# 服务端口
PORT=8082

# 数据库配置（如果需要）
SSE_DB_PATH=/app/sse_pe_data.db

# 开发环境
DEBUG=true
FLASK_ENV=development
